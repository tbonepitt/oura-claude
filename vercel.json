{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "public/**",    "use": "@vercel/static" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",       "value": "nosniff" },
        { "key": "X-Frame-Options",              "value": "DENY" },
        { "key": "Referrer-Policy",              "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security",    "value": "max-age=63072000; includeSubDomains" },
        { "key": "Permissions-Policy",           "value": "geolocation=(), microphone=(), camera=()" },
        { "key": "Content-Security-Policy",      "value": "default-src 'self'; script-src 'self' 'unsafe-inline' cdn.jsdelivr.net va.vercel-scripts.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://api.ouraring.com https://cloud.ouraring.com; font-src 'self'; frame-ancestors 'none'" }
      ]
    }
  ],
  "routes": [
    { "src": "/api/(.*)",      "dest": "/api/index.py" },
    { "src": "/privacy",       "dest": "/public/privacy.html" },
    { "src": "/terms",         "dest": "/public/terms.html" },
    { "src": "/auth/callback", "dest": "/public/index.html" },
    { "src": "/(.*)",          "dest": "/public/index.html" }
  ]
}
